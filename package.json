{
  "name": "pageon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "author": "Rentheria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rentheria/pageon.git"
  },
  "homepage": "https://github.com/rentheria/pageon",
  "bugs": {
    "url": "https://github.com/rentheria/pageon/issues"
  },
  "scripts": {
    "dev": "pnpm --filter @pageon/vanilla-js dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @pageon/core test",
    "build:angular": "pnpm --filter @pageon/angular build",
    "dev:angular": "pnpm --filter @pageon/angular dev",
    "typecheck:angular": "pnpm --filter @pageon/angular typecheck",
    "build:ionic": "pnpm --filter @pageon/ionic build",
    "dev:ionic-example": "pnpm --filter @pageon/ionic-example dev"
  }
}
