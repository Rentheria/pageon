{
  "name": "@pageon/angular",
  "version": "0.1.0",
  "description": "Angular adapter for @pageon/core PDF viewer with component bindings and event outputs",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "pdf",
    "viewer",
    "angular",
    "pageon",
    "pdf-viewer",
    "angular-component",
    "document-viewer"
  ],
  "author": "Rentheria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rentheria/pageon.git",
    "directory": "packages/angular"
  },
  "homepage": "https://github.com/rentheria/pageon",
  "bugs": {
    "url": "https://github.com/rentheria/pageon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && shx mkdir -p dist/lib/pageon-viewer && shx cp src/lib/pageon-viewer/pageon-viewer.component.html dist/lib/pageon-viewer/pageon-viewer.component.html && shx cp src/lib/pageon-viewer/pageon-viewer.component.scss dist/lib/pageon-viewer/pageon-viewer.component.scss",
    "prepublishOnly": "pnpm run build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0 <19.0.0",
    "@angular/core": ">=16.0.0 <19.0.0",
    "@pageon/core": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^18.2.13",
    "@angular/core": "^18.2.13",
    "@angular/platform-browser": "^18.2.13",
    "@angular/platform-browser-dynamic": "^18.2.13",
    "@pageon/core": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1",
    "zone.js": "^0.14.10"
  }
}
