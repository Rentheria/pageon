{
  "name": "@pageon/core",
  "version": "0.1.0",
  "description": "Modern, extensible PDF viewer with page-turn animations, gestures, keyboard navigation, and smart caching",
  "type": "module",
  "main": "dist/pageon-core.js",
  "module": "dist/pageon-core.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pageon-core.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "pdf",
    "viewer",
    "page-turn",
    "pageon",
    "pdf-viewer",
    "document-viewer",
    "canvas",
    "gestures",
    "keyboard",
    "responsive"
  ],
  "author": "Rentheria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rentheria/pageon.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rentheria/pageon",
  "bugs": {
    "url": "https://github.com/rentheria/pageon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.2.0",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1"
  }
}
