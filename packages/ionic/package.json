{
  "name": "@pageon/ionic",
  "version": "0.1.0",
  "description": "Ionic adapter for @pageon/core PDF viewer with mobile-optimized components and touch controls",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "pdf",
    "viewer",
    "ionic",
    "angular",
    "pageon",
    "pdf-viewer",
    "mobile",
    "document-viewer"
  ],
  "author": "Rentheria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rentheria/pageon.git",
    "directory": "packages/ionic"
  },
  "homepage": "https://github.com/rentheria/pageon",
  "bugs": {
    "url": "https://github.com/rentheria/pageon/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && shx mkdir -p dist/lib/pageon-ionic-viewer && shx cp src/lib/pageon-ionic-viewer/pageon-ionic-viewer.component.html dist/lib/pageon-ionic-viewer/pageon-ionic-viewer.component.html && shx cp src/lib/pageon-ionic-viewer/pageon-ionic-viewer.component.scss dist/lib/pageon-ionic-viewer/pageon-ionic-viewer.component.scss",
    "prepublishOnly": "pnpm run build",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0 <19.0.0",
    "@angular/core": ">=16.0.0 <19.0.0",
    "@ionic/angular": ">=7.0.0",
    "@pageon/core": "workspace:*",
    "@pageon/angular": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^18.2.13",
    "@angular/core": "^18.2.13",
    "@ionic/angular": "^8.5.7",
    "@pageon/angular": "workspace:*",
    "@pageon/core": "workspace:*",
    "typescript": "^5.8.3"
  }
}
